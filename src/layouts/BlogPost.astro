---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '.././components/BaseHead.astro';
import Footer from '.././components/Footer.astro';
import FormattedDate from '.././components/FormattedDate.astro';
import Header from '.././components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
const { heroImageCaption } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main {
        width: calc(100% - 2em);
        max-width: 100%;
        margin: 0;
      }
      .hero-image {
        width: 50%;
        margin: auto
      }
      .hero-image img {
        display: block;
        margin: 0 auto;
        border-radius: 12px;
        box-shadow: var(--box-shadow);
      }
      .hero-caption {
        margin: 0.75rem auto 0;
        max-width: 1020px;
        padding: 0 1rem;
        color: rgb(var(--gray));
        font-size: 0.95rem;
        text-align: center;
        font-style: italic;
      }
      .prose {
        width: 720px;
        max-width: calc(100% - 2em);
        margin: auto;
        padding: 1em;
        color: rgb(var(--gray-dark));
      }
      .title {
        margin-bottom: 1em;
        padding: 1em 0;
        text-align: center;
        line-height: 1;
      }
      .main-title {
        width: min(18ch, calc(100% - 2rem));
        margin: 1.25rem auto 0.75rem;
        text-align: center;
        line-height: 1.1;
        text-wrap: balance;
        font-size: clamp(1.7rem, 3vw, 2.5rem);
      }
      .date {
        margin-bottom: 0.5em;
        color: rgb(var(--gray));
      }
      .last-updated-on {
        font-style: italic;
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
        <h1 class="main-title">{title}</h1>
      <article >
        <div class="hero-image">
            <hr />
          {heroImage && <Image src={heroImage} alt="" />}
          {heroImageCaption && <p class="hero-caption">{heroImageCaption}</p>}
        </div>
        <div class="prose">
          <div class="title">
            <div class="date">
              <FormattedDate date={pubDate} />
              {
                updatedDate && (
                  <div class="last-updated-on">
                    Last updated on <FormattedDate date={updatedDate} />
                  </div>
                )
              }
            </div>
            
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

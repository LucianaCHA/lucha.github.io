---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '.././components/BaseHead.astro';
import Footer from '.././components/Footer.astro';
import FormattedDate from '.././components/FormattedDate.astro';
import Header from '.././components/Header.astro';

type BlogEntry = CollectionEntry<'blog'>;

type Props = BlogEntry['data'] & {
  prevPost?: BlogEntry;
  nextPost?: BlogEntry;
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroImageCaption,
  lang,
  prevPost,
  nextPost,
} = Astro.props as Props;

const base = import.meta.env.BASE_URL;
const getPostHref = (post: BlogEntry) => {
  const postSlug = post.data.postSlug ?? post.id;
  const postLang = post.data.lang ?? 'en';
  return `${base}blog/${postSlug}/${postLang}/`;
};

const previousLabel = lang === 'es' ? 'Anterior' : 'Previous';
const nextLabel = lang === 'es' ? 'Siguiente' : 'Next';
---

<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} />
    <style>
      main {
        margin: 0;
      }
      article {
        width: min(100%, 760px);
        margin: 0 auto;
        max-width: 100%;
      }
      .prose {
        padding: 1em;
        color: rgb(var(--gray-dark));
        width: 100%;
        box-sizing: border-box;
      }
      .hero-image {
        width: 100%;
        box-sizing: border-box;
      }
      .post-title {
        margin: 0 0 0.75rem;
        //font-size: clamp(2.7rem, 7vw, 4.2rem);
        line-height: 1.06;
        text-wrap: balance;
      }
      .post-nav {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgb(var(--gray-light));
      }
      .post-nav-link {
        flex: 1 1 16rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        padding: 1rem;
        border: 1px solid rgba(var(--gray), 0.18);
        border-radius: 1rem;
        text-decoration: none;
        background: rgba(var(--gray-light), 0.2);
      }
      .post-nav-link:hover {
        border-color: rgba(var(--accent), 0.35);
        box-shadow: var(--box-shadow);
      }
      .post-nav-link.next {
        text-align: right;
        align-items: flex-end;
      }
      .post-nav-label {
        color: rgb(var(--gray));
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }
      .post-nav-title {
        color: rgb(var(--black));
        font-weight: 700;
        line-height: 1.3;
      }
      @media (max-width: 640px) {
        article {
          margin: 0;
        }
        .prose {
          padding: 0.75em;
        }
        .post-title {
          font-size: clamp(2rem, 10vw, 2.8rem);
        }
        .post-nav {
          flex-direction: column;
        }
        .post-nav-link.next {
          text-align: left;
          align-items: flex-start;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article >
        <div class="hero-image">
            <hr />
          {heroImage && <Image src={heroImage} alt="" />}
          {heroImageCaption && <p class="hero-caption">{heroImageCaption}</p>}
        </div>
        <div class="prose">
          <div class="title">
            <h1 class="post-title">{title}</h1>
            <div class="date">
              <FormattedDate date={pubDate} />
                <hr/>
              {
                updatedDate && (
                  <div class="last-updated-on">
                    Last updated on <FormattedDate date={updatedDate} />
                  </div>
                )
              }
            </div>
            
          </div>
          <slot />
          {(prevPost || nextPost) && (
            <nav class="post-nav" aria-label="Post navigation">
              {prevPost && (
                <a class="post-nav-link prev" href={getPostHref(prevPost)}>
                  <span class="post-nav-label">{previousLabel}</span>
                  <span class="post-nav-title">{prevPost.data.title}</span>
                </a>
              )}
              {nextPost && (
                <a class="post-nav-link next" href={getPostHref(nextPost)}>
                  <span class="post-nav-label">{nextLabel}</span>
                  <span class="post-nav-title">{nextPost.data.title}</span>
                </a>
              )}
            </nav>
          )}
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
